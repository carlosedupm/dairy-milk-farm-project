 "item": [
  {
   "name": "Authentication",
   "description": "JWT authentication endpoints",
   "item": [
    {
     "name": "Login",
     "request": {
      "method": "POST",
      "header": [
       {
        "key": "Content-Type",
        "value": "application/json"
       }
      ],
      "body": {
       "mode": "raw",
       "raw": "{\n  \"email\": \"admin@ceialmilk.com\",\n  \"password\": \"password\"\n}"
      },
      "url": {
       "raw": "{{baseUrl}}/api/auth/login",
       "host": [
        "{{baseUrl}}"
       ],
       "path": [
        "api",
        "auth",
        "login"
       ]
      }
     },
     "response": [],
     "event": [
      {
       "listen": "test",
       "script": {
        "exec": [
         "// Save the authentication token",
         "var jsonData = pm.response.json();",
         "pm.environment.set(\"authToken\", jsonData.token);",
         "console.log(\"Token saved to environment: \" + pm.environment.get(\"authToken\"));",
         "",
         "// Test response structure",
         "pm.test(\"Status code is 200\", function () {",
         "    pm.response.to.have.status(200);",
         "});",
         "pm.test(\"Response has token\", function () {",
         "    pm.expect(jsonData).to.have.property('token');",
         "});",
         "pm.test(\"Response has email\", function () {",
         "    pm.expect(jsonData).to.have.property('email');",
         "});",
         "pm.test(\"Response has profile\", function () {",
         "    pm.expect(jsonData).to.have.property('perfil');",
         "});"
        ],
        "type": "text/javascript"
       }
      }
     ]
    },
    {
     "name": "Validate Token",
     "request": {
      "method": "POST",
      "header": [
       {
        "key": "Content-Type",
        "value": "text/plain"
       },
       {
        "key": "Authorization",
        "value": "Bearer {{authToken}}"
       }
      ],
      "body": {
       "mode": "raw",
       "raw": "{{authToken}}"
      },
      "url": {
       "raw": "{{baseUrl}}/api/auth/validate",
       "host": [
        "{{baseUrl}}"
       ],
       "path": [
        "api",
        "auth",
        "validate"
       ]
      }
     },
     "response": []
    }
   ]
