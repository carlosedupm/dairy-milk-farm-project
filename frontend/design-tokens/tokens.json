{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "CeialMilk Design Tokens — dicionário W3C DTCG. Runtime: frontend/src/app/globals.css. Manter sincronizado ao alterar primitivos ou semânticos.",
  "color": {
    "primitive": {
      "background": {
        "$type": "color",
        "$description": "Fundo base da aplicação",
        "$value": {
          "colorSpace": "hsl",
          "components": ["{color.primitive.background.light}", "{color.primitive.background.dark}"]
        },
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [40, 0.18, 0.97] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.18, 0.11] }
        }
      },
      "foreground": {
        "$type": "color",
        "$description": "Texto principal",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [24, 0.12, 0.12] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [40, 0.15, 0.95] }
        }
      },
      "primary": {
        "$type": "color",
        "$description": "Verde pastagem — marca",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.42, 0.36] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.48, 0.48] }
        }
      },
      "destructive": {
        "$type": "color",
        "$description": "Erro / ação destrutiva",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [0, 0.72, 0.51] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [0, 0.55, 0.45] }
        }
      }
    },
    "surface": {
      "primary": {
        "$type": "color",
        "$description": "Superfície principal — alias de background",
        "$value": "{color.primitive.background}"
      },
      "secondary": {
        "$type": "color",
        "$description": "Superfície secundária — alias de muted",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [40, 0.18, 0.93] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.12, 0.20] }
        }
      },
      "elevated": {
        "$type": "color",
        "$description": "Cards e painéis elevados",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [0, 0, 1] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.16, 0.14] }
        }
      },
      "overlay": {
        "$type": "color",
        "$description": "Popovers e overlays",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [0, 0, 1] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.16, 0.14] }
        }
      }
    },
    "text": {
      "primary": {
        "$type": "color",
        "$description": "Texto principal — alias de foreground",
        "$value": "{color.primitive.foreground}"
      },
      "secondary": {
        "$type": "color",
        "$description": "Texto secundário / metadados",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [24, 0.10, 0.42] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [40, 0.12, 0.65] }
        }
      }
    },
    "border": {
      "default": {
        "$type": "color",
        "$description": "Bordas padrão",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [40, 0.14, 0.88] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.12, 0.22] }
        }
      },
      "focus": {
        "$type": "color",
        "$description": "Anel de foco — alias de ring/primary",
        "$value": "{color.primitive.primary}"
      }
    },
    "brand": {
      "primary": {
        "$type": "color",
        "$description": "Cor de marca principal",
        "$value": "{color.primitive.primary}"
      }
    },
    "feedback": {
      "success": {
        "$type": "color",
        "$description": "Sucesso / confirmação",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.55, 0.32] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [152, 0.48, 0.48] }
        }
      },
      "warning": {
        "$type": "color",
        "$description": "Aviso / atenção",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [32, 0.95, 0.44] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [38, 0.92, 0.50] }
        }
      },
      "error": {
        "$type": "color",
        "$description": "Erro — alias de destructive",
        "$value": "{color.primitive.destructive}"
      },
      "info": {
        "$type": "color",
        "$description": "Informação",
        "light": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [217, 0.91, 0.48] }
        },
        "dark": {
          "$type": "color",
          "$value": { "colorSpace": "hsl", "components": [217, 0.91, 0.60] }
        }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["Inter", "system-ui", "sans-serif"],
        "$description": "Família principal — carregada via next/font em layout.tsx"
      }
    },
    "fontSize": {
      "xs": {
        "$type": "dimension",
        "$value": "0.75rem",
        "$description": "12px — uso restrito (badges, metadados compactos)"
      },
      "sm": {
        "$type": "dimension",
        "$value": "0.875rem",
        "$description": "14px — texto small (RF02 mínimo)"
      },
      "base": {
        "$type": "dimension",
        "$value": "1rem",
        "$description": "16px — corpo e labels (RF02 mínimo body)"
      },
      "lg": {
        "$type": "dimension",
        "$value": "1.125rem",
        "$description": "18px — subtítulos"
      },
      "xl": {
        "$type": "dimension",
        "$value": "1.25rem",
        "$description": "20px — títulos de página"
      },
      "2xl": {
        "$type": "dimension",
        "$value": "1.5rem",
        "$description": "24px — títulos de secção"
      }
    },
    "fontWeight": {
      "normal": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": 1.25 },
      "snug": { "$type": "number", "$value": 1.375 },
      "normal": { "$type": "number", "$value": 1.5 },
      "relaxed": { "$type": "number", "$value": 1.625 }
    },
    "letterSpacing": {
      "tight": { "$type": "dimension", "$value": "-0.025em" },
      "normal": { "$type": "dimension", "$value": "0em" },
      "wide": { "$type": "dimension", "$value": "0.025em" }
    }
  },
  "spacing": {
    "1": { "$type": "dimension", "$value": "0.25rem", "$description": "4px — base grid" },
    "2": { "$type": "dimension", "$value": "0.5rem", "$description": "8px" },
    "3": { "$type": "dimension", "$value": "0.75rem", "$description": "12px" },
    "4": { "$type": "dimension", "$value": "1rem", "$description": "16px" },
    "5": { "$type": "dimension", "$value": "1.25rem", "$description": "20px" },
    "6": { "$type": "dimension", "$value": "1.5rem", "$description": "24px" },
    "8": { "$type": "dimension", "$value": "2rem", "$description": "32px" },
    "10": { "$type": "dimension", "$value": "2.5rem", "$description": "40px" },
    "12": { "$type": "dimension", "$value": "3rem", "$description": "48px" },
    "16": { "$type": "dimension", "$value": "4rem", "$description": "64px" },
    "20": { "$type": "dimension", "$value": "5rem", "$description": "80px" },
    "24": { "$type": "dimension", "$value": "6rem", "$description": "96px" }
  },
  "borderRadius": {
    "none": { "$type": "dimension", "$value": "0" },
    "sm": { "$type": "dimension", "$value": "calc(0.625rem - 4px)", "$description": "6px com --radius padrão" },
    "md": { "$type": "dimension", "$value": "calc(0.625rem - 2px)", "$description": "8px com --radius padrão" },
    "lg": { "$type": "dimension", "$value": "0.625rem", "$description": "10px — --radius base" },
    "xl": { "$type": "dimension", "$value": "calc(0.625rem + 4px)", "$description": "14px com --radius padrão" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "elevation1": {
      "$type": "shadow",
      "$value": {
        "color": "rgb(0 0 0 / 0.05)",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px"
      },
      "$description": "Equivalente a shadow-sm / elevação baixa"
    },
    "elevation2": {
      "$type": "shadow",
      "$value": [
        {
          "color": "rgb(0 0 0 / 0.1)",
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "-1px"
        },
        {
          "color": "rgb(0 0 0 / 0.1)",
          "offsetX": "0px",
          "offsetY": "2px",
          "blur": "4px",
          "spread": "-2px"
        }
      ],
      "$description": "Equivalente a shadow-md"
    },
    "elevation3": {
      "$type": "shadow",
      "$value": [
        {
          "color": "rgb(0 0 0 / 0.1)",
          "offsetX": "0px",
          "offsetY": "10px",
          "blur": "15px",
          "spread": "-3px"
        },
        {
          "color": "rgb(0 0 0 / 0.1)",
          "offsetX": "0px",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "-4px"
        }
      ],
      "$description": "Equivalente a shadow-lg"
    },
    "elevation4": {
      "$type": "shadow",
      "$value": [
        {
          "color": "rgb(0 0 0 / 0.1)",
          "offsetX": "0px",
          "offsetY": "20px",
          "blur": "25px",
          "spread": "-5px"
        },
        {
          "color": "rgb(0 0 0 / 0.1)",
          "offsetX": "0px",
          "offsetY": "8px",
          "blur": "10px",
          "spread": "-6px"
        }
      ],
      "$description": "Equivalente a shadow-xl"
    }
  },
  "breakpoint": {
    "sm": { "$type": "dimension", "$value": "640px" },
    "md": { "$type": "dimension", "$value": "768px" },
    "lg": { "$type": "dimension", "$value": "1024px" },
    "xl": { "$type": "dimension", "$value": "1280px" },
    "2xl": { "$type": "dimension", "$value": "1536px" }
  }
}
